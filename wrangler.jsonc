{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "toolhub",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-09",

  "observability": {
    "enabled": true
  },

  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },

  "compatibility_flags": [
    "nodejs_compat"
  ]
}
